# TruScan Systems - Environment Variables
# Copy this to .env and fill in the values

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Admin Configuration
ADMIN_CODE=TS-ADMIN-2026

# Application Mode
# Set to 'true' to enable mock OTPs and bypass some Supabase checks during development
MOCK_MODE=true

# Port (Default: 3000)
PORT=3000
